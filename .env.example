# Daily Intelligence Brief v9-lite
# 複製此檔案為 .env 並填入你的 API keys

# Gemini API (必要)
GOOGLE_API_KEY=your_google_api_key_here

# FRED 經濟資料 (必要)
FRED_API_KEY=your_fred_api_key_here

# EIA 原油資料 (選填，需至 https://www.eia.gov/opendata/ 申請)
EIA_API_KEY=

# Notion Integration (必要)
# 1. 到 https://www.notion.so/my-integrations 建立 integration
# 2. 取得 Internal Integration Secret
NOTION_TOKEN=your_notion_token_here

# Notion Database ID (必要)
# 1. 建立一個新的 Notion Database (表格)
# 2. 分享給你的 integration
# 3. 從 URL 中取得 database ID
#    https://www.notion.so/{workspace}/{database_id}?v=...
NOTION_DATABASE_ID=your_notion_database_id_here
